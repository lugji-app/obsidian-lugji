{
	"name": "lugji-obsidian",
	"version": "1.0.0",
	"description": "Obsidian plugin for Lugji — Cantonese/Mandarin meeting AI. Reads meeting notes written by the Lugji iOS app and enriches them with metadata, smart linking, and dashboards.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [
		"obsidian",
		"lugji",
		"meeting",
		"cantonese",
		"transcription"
	],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^20",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^2.1.9",
		"yaml": "^2.9.0"
	},
	"dependencies": {
		"obsidian": "^1.4.0"
	}
}
